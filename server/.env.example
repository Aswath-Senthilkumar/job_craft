# ===========================================
# Job Tracker Server - Environment Config
# ===========================================
# Copy this file to .env and fill in your values

# Gmail OAuth credentials
GMAIL_CLIENT_ID=<your_gmail_client_id>
GMAIL_CLIENT_SECRET=<your_gmail_client_secret>
GMAIL_REDIRECT_URI=http://localhost:3002/api/gmail/callback

# Token Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
GMAIL_ENCRYPTION_KEY=<64_char_hex_string>

# ── Override only if deploying to a custom domain ──
# PORT=3002
# CLIENT_URL=http://localhost:5174

# ── InsForge Backend (Required) ──
INSFORGE_BASE_URL=https://your-project.region.insforge.app
INSFORGE_API_KEY=your_insforge_api_key
