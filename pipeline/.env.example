# ===========================================
# Job Automation Pipeline - Environment Config
# ===========================================
# Copy this file to .env and fill in your values
# All job search settings (keywords, countries, scrapers, etc.)
# are configured in the dashboard UI — not here.

# ── Google Gemini (AI) ──
GEMINI_API_KEY=<your_gemini_api_key>

# ── Apify / LinkedIn (optional, has free tier) ──
APIFY_API_TOKEN=<your_apify_api_token>
APIFY_ACTOR_ID=<your_apify_actor_id>

# ── Job Tracker API ──
JOB_TRACKER_URL=http://localhost:3002

# ── PDF Generation Backend ──
PDF_BACKEND_URL=<your_pdf_backend_url>

# ── CareerJet (optional) ──
CAREERJET_AFFILIATE_ID=<your_careerjet_affiliate_id>
